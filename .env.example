# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_db

# Ollama LLM
OLLAMA_URL=http://localhost:11434/api/generate
LLM_MODEL=llama3.2

# Embedding Model
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Index Configuration
INDEX_TYPE=ivfflat
IVF_LISTS=100
HNSW_M=16
HNSW_EFCONSTRUCTION=200
